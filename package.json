{
  "name": "aiscr-webamcr",
  "version": "1.0.0",
  "private": true,
  "description": "JavaScript dependency management for AMCR web client",
  "scripts": {
    "openspec:validate": "node ./node_modules/@fission-ai/openspec/bin/openspec.js validate --all",
    "openspec:cli": "node ./node_modules/@fission-ai/openspec/bin/openspec.js",
    "openspec:update": "node ./node_modules/@fission-ai/openspec/bin/openspec.js update",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "bootstrap-datepicker": "1.10.1",
    "bootstrap-icons": "1.13.1",
    "bootstrap-select": "1.14.0-beta3",
    "daterangepicker": "3.1.0",
    "dropzone": "5.9.3",
    "jquery": "3.7.1",
    "leaflet": "1.9.4",
    "leaflet-draw": "1.0.4",
    "leaflet-fullscreen": "1.0.2",
    "leaflet-spin": "1.1.2",
    "leaflet.featuregroup.subgroup": "1.0.2",
    "leaflet.markercluster": "1.5.3",
    "moment": "2.30.1",
    "spin.js": "2.3.2"
  },
  "devDependencies": {
    "@fission-ai/openspec": "1.3.1",
    "patch-package": "8.0.1"
  }
}
