[flake8]
ignore = D203, E231, E501, E702, W503, E203
per-file-ignores =
    webclient/webclient/settings/github_ci.py: F403, F405
max-line-length = 120
exclude =
    .git,
    __pycache__,
    venv,
    .idea,
	dev.py,
	local_test.py,
	production.py,
	dev_test.py,
	docs.py,
	apps.py,
	*/migrations/*
