    <amcr:pristupnost id="{PRISTUPNOST_IDENT}" xml:lang="cs">{PRISTUPNOST_IDENT}</amcr:pristupnost>
    <amcr:chranene_udaje>
      <amcr:lokalizace>u lesa</amcr:lokalizace>
      <amcr:geom_wkt EPSG="4326">POINT(14.42 50.08)</amcr:geom_wkt>
